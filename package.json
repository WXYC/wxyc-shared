{
  "name": "@wxyc/shared",
  "version": "2.0.0",
  "description": "Shared DTOs, validation, test utilities, and E2E tests for WXYC services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dtos": {
      "types": "./dist/dtos/index.d.ts",
      "import": "./dist/dtos/index.js",
      "default": "./dist/dtos/index.js"
    },
    "./auto-dj": {
      "types": "./dist/auto-dj/index.d.ts",
      "import": "./dist/auto-dj/index.js",
      "default": "./dist/auto-dj/index.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils/index.d.ts",
      "import": "./dist/test-utils/index.js",
      "default": "./dist/test-utils/index.js"
    },
    "./auth-client": {
      "types": "./dist/auth-client/index.d.ts",
      "import": "./dist/auth-client/index.js",
      "default": "./dist/auth-client/index.js"
    },
    "./auth-client/auth": {
      "types": "./dist/auth-client/auth.d.ts",
      "import": "./dist/auth-client/auth.js",
      "default": "./dist/auth-client/auth.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js",
      "default": "./dist/validation/index.js"
    }
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "npm run generate:typescript && npm run build",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:contracts": "vitest run --config vitest.e2e.config.ts tests/e2e-contracts.test.ts",
    "test:setup-script": "bats scripts/__tests__/setup-dev-environment.test.sh",
    "test:drift-guard": "bats scripts/__tests__/check-corpus-drift.test.sh",
    "test:bs-lml-gate": "bats scripts/__tests__/bs-lml-gate/*.test.sh",
    "lint": "tsc --noEmit --declaration false --declarationMap false",
    "clean": "rm -rf dist",
    "generate": "npm run generate:typescript && npm run generate:python && npm run generate:swift && npm run generate:kotlin",
    "generate:typescript": "node scripts/generate-models.js",
    "generate:swift": "openapi-generator-cli generate -i api.yaml -g swift5 -o generated/swift -c openapi-config/swift.yaml --skip-validate-spec",
    "generate:python": "datamodel-codegen --input api.yaml --input-file-type openapi --output generated/python/models.py --output-model-type pydantic_v2.BaseModel --target-python-version 3.12 --use-standard-collections --use-union-operator",
    "generate:kotlin": "openapi-generator-cli generate -i api.yaml -g kotlin -o generated/kotlin -c openapi-config/kotlin.yaml --skip-validate-spec",
    "check:breaking": "bash scripts/check-breaking-changes.sh"
  },
  "files": [
    "dist",
    "api.yaml",
    "src/test-utils/wxyc-example-data.json",
    "src/test-utils/charset-torture.json"
  ],
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.39.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "bats": "^1.11.0",
    "better-auth": "^1.6.23",
    "openapi-typescript": "^7.13.0",
    "postgres": "^3.4.9",
    "tsup": "^8.4.0",
    "typescript": "^5.6.2 || ^6.0.0",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "better-auth": "^1.5.0",
    "typescript": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "better-auth": {
      "optional": true
    }
  },
  "keywords": [
    "wxyc",
    "dto",
    "testing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WXYC/wxyc-shared.git"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "date-fns": "^4.4.0"
  }
}
