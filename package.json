{
  "name": "@wxyc/shared",
  "version": "0.7.0",
  "description": "Shared DTOs, validation, test utilities, and E2E tests for WXYC services",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dtos": {
      "types": "./dist/dtos/index.d.ts",
      "import": "./dist/dtos/index.js",
      "default": "./dist/dtos/index.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils/index.d.ts",
      "import": "./dist/test-utils/index.js",
      "default": "./dist/test-utils/index.js"
    },
    "./auth-client": {
      "types": "./dist/auth-client/index.d.ts",
      "import": "./dist/auth-client/index.js",
      "default": "./dist/auth-client/index.js"
    },
    "./auth-client/auth": {
      "types": "./dist/auth-client/auth.d.ts",
      "import": "./dist/auth-client/auth.js",
      "default": "./dist/auth-client/auth.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js",
      "default": "./dist/validation/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepare": "npm run generate:typescript && npm run build",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:setup-script": "bats scripts/__tests__/setup-dev-environment.test.sh",
    "lint": "tsc --noEmit --declaration false --declarationMap false",
    "clean": "rm -rf dist",
    "generate": "npm run generate:typescript && npm run generate:python && npm run generate:swift && npm run generate:kotlin",
    "generate:typescript": "node scripts/generate-models.js",
    "generate:swift": "openapi-generator-cli generate -i api.yaml -g swift5 -o ../wxyc-ios-64-copy/Shared/WXYCAPI -c openapi-config/swift.yaml --skip-validate-spec",
    "generate:python": "datamodel-codegen --input api.yaml --input-file-type openapi --output generated/python/models.py --output-model-type pydantic_v2.BaseModel --target-python-version 3.12 --use-standard-collections --use-union-operator",
    "generate:kotlin": "openapi-generator-cli generate -i api.yaml -g kotlin -o ../WXYC-Android/shared/api -c openapi-config/kotlin.yaml --skip-validate-spec",
    "check:breaking": "bash scripts/check-breaking-changes.sh"
  },
  "files": [
    "dist",
    "api.yaml",
    "src/test-utils/wxyc-example-data.json"
  ],
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.15.3",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "bats": "^1.11.0",
    "better-auth": "^1.5.6",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.4.0",
    "typescript": "^5.6.2 || ^6.0.0",
    "vitest": "^2.0.0",
    "yaml": "^2.6.0"
  },
  "peerDependencies": {
    "better-auth": "^1.5.0",
    "typescript": "^5.0.0 || ^6.0.0"
  },
  "keywords": [
    "wxyc",
    "dto",
    "testing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WXYC/wxyc-shared.git"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "date-fns": "^4.1.0"
  }
}
